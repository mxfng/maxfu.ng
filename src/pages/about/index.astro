---
import Layout from "@/layouts/layout.astro";
import { EMAIL } from "@/content/email";
import { URLS } from "@/content/urls";
---

<Layout title="About">
	<div class="w-full space-y-12">
		<h1 class="animate-fade-in-up opacity-0" style="animation-delay: 0s;">About</h1>
		<div
			class="animate-fade-in-up max-w-screen-sm space-y-6 opacity-0"
			style="animation-delay: 0.05s;"
		>
			<p>
				Musician, developer, and designer living in Los Angeles. I build things for the web, make
				music as Max Fung and Toko Makai, and write about the things I care about.
			</p>
		</div>
		<section class="animate-fade-in-up space-y-3 opacity-0" style="animation-delay: 0.1s;">
			<h2 class="text-lg font-medium">Contact</h2>
			<ul class="space-y-2">
				<li>
					<a
						href={`mailto:${EMAIL}`}
						class="text-muted-foreground hover:text-accent transition-colors"
					>
						{EMAIL}
					</a>
				</li>
				<li>
					<a
						href={URLS.GITHUB.url}
						target="_blank"
						rel="noopener noreferrer"
						class="text-muted-foreground hover:text-accent transition-colors"
					>
						GitHub
					</a>
				</li>
				<li>
					<a
						href={URLS.LINKEDIN.url}
						target="_blank"
						rel="noopener noreferrer"
						class="text-muted-foreground hover:text-accent transition-colors"
					>
						LinkedIn
					</a>
				</li>
			</ul>
		</section>
	</div>
</Layout>

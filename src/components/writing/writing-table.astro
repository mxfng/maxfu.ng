---
import type { CollectionEntry } from "astro:content";

interface Props {
  writings: CollectionEntry<"writing">[];
}

const { writings } = Astro.props;

const sortedWritings = writings?.length
  ? [...writings].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  : [];
---

<div class="w-full">
  {
    sortedWritings.map((writing, i) => (
      <a
        href={`/writing/${writing.slug}`}
        class="animate-fade-in-up group flex min-h-12 items-center border-t py-3 no-underline opacity-0"
        style={`animation-delay: ${0.1 + i * 0.05}s;`}
      >
        <span class="group-hover:text-accent flex-1 transition-colors">
          {writing.data.title}
        </span>
        <time
          datetime={writing.data.date.toISOString()}
          class="text-muted-foreground shrink-0 pl-4"
        >
          {writing.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
          })}
        </time>
      </a>
    ))
  }
</div>

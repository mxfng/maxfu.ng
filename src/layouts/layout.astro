---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import MinimalHeader from "@/components/nav/minimal-header.astro";

import SEO from "@/components/seo.astro";

interface Props {
  title?: string;
  description?: string;
  slug?: string;
  image?: string;
}

const { title, description, slug, image } = Astro.props;
---

<!doctype html>
<html lang="en" style="view-transition-name:root">
  <head>
    <SEO
      title={title}
      description={description}
      url={Astro.url?.href}
      slug={slug}
      image={image}
    />
    <ClientRouter />
  </head>
  <body class="flex min-h-dvh flex-col font-sans">
    <MinimalHeader />
    <main
      class="page-container mt-12 flex flex-1 flex-col pb-16 md:mt-16 md:pb-24"
    >
      <slot />
    </main>
  </body>
</html>

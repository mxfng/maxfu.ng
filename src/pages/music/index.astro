---
import Layout from "@/layouts/layout.astro";
import { Image } from "astro:assets";
import WritingTable from "@/components/writing/writing-table.astro";
import { getWritings } from "@/lib/get-collection";
import coverLotus from "@/assets/images/cover-lotus.png";
import coverBlueMoon from "@/assets/images/cover-blue-moon.jpg";
const GRID_COLS = 2;

const writings = await getWritings();
const musicWritings = writings.filter((w) => w.data.music);

const videos = [
  {
    id: "9CNIUWSzqbc",
    title: "See Through",
    label: "Video",
    year: 2020,
  },
  {
    id: "vXpejWS-UjU",
    title: "Honesty",
    label: "Trailer",
    year: 2020,
  },
  {
    id: "G89Wpx9ex0U",
    title: "Smoke",
    label: "Video",
    year: 2019,
  },
  {
    id: "22mM4PnUYjg",
    title: "Smoke",
    label: "Trailer",
    year: 2019,
  },
  {
    id: "O2LMWKSoY6U",
    title: "Anything",
    label: "Trailer",
    year: 2019,
  },
  {
    id: "6UeD57wDPZc",
    title: "Sweet Dreams",
    label: "Trailer",
    year: 2019,
  },
];

const albums = [
  {
    cover: coverBlueMoon,
    title: "Blue Moon",
    year: 2020,
    url: "https://album.link/br4hxrq46kx07",
  },
  {
    cover: coverLotus,
    title: "Lotus",
    year: 2019,
    url: "https://album.link/xkrc4cgctwccj",
  },
];
---

<Layout title="Music">
  <div class="w-full space-y-16">
    <h1>Music</h1>
    <section>
      <ul class="grid grid-cols-2 gap-4 sm:gap-6">
        {
          albums.map((album, i) => (
            <li>
              <a
                href={album.url}
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline"
              >
                <Image
                  src={album.cover}
                  alt={`${album.title} album cover`}
                  width={800}
                  loading={i < GRID_COLS ? "eager" : "lazy"}
                  class="aspect-square w-full rounded-lg object-cover transition-opacity hover:opacity-80"
                />
                <p class="mt-3 text-sm font-medium">
                  {album.title}
                  <span class="text-muted-foreground ml-1.5">{album.year}</span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="space-y-6">
      <h2>Videos</h2>
      <ul class="grid grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-6">
        {
          videos.map((video) => (
            <li>
              <a
                href={`https://www.youtube.com/watch?v=${video.id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline"
              >
                <img
                  src={`https://img.youtube.com/vi/${video.id}/maxresdefault.jpg`}
                  alt={`${video.title} - ${video.label}`}
                  width={480}
                  height={360}
                  loading="lazy"
                  class="aspect-video w-full rounded-lg object-cover transition-opacity hover:opacity-80"
                />
                <p class="mt-3 text-sm font-medium">
                  {video.title}
                  <span class="text-muted-foreground ml-1.5">
                    {video.label} · {video.year}
                  </span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    {
      musicWritings.length > 0 && (
        <section class="space-y-6">
          <h2>Updates</h2>
          <WritingTable writings={musicWritings} />
        </section>
      )
    }
  </div>
</Layout>

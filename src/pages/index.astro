---
import HubLayout from "@/layouts/hub-layout.astro";
import JanZoeng from "@/components/jan-zoeng.astro";
---

<HubLayout>
  <div class="prose">
    <section>
      <h3>Max Fung</h3>
    </section>
    <div>
      <p>
        Building for the web, making music, and writing about the things I care
        about. Based in Los Angeles. Creator of <a
          href="https://drumha.us/"
          target="_blank"
          rel="noopener noreferrer">Drumhaus</a
        >, a drum machine for the browser.
      </p>
      <p>
        I've been an engineer at places like Boeing, Flexe, and Dirac. Currently
        founding engineer at a stealth startup. If you need help building
        something, <a href={`mailto:m@maxfu.ng`}>reach out</a>.
      </p>
      <p>
        You can read my <a href="/writing">writing</a>, listen to my <a
          href="/music">music</a
        >, find me on <a
          href="https://github.com/mxfng"
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >, or say hello at <a href={`mailto:m@maxfu.ng`}>m@maxfu.ng</a>.
      </p>
    </div>
    <JanZoeng />
  </div>
</HubLayout>

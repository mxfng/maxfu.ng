{
	"name": "fung.studio",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"tsc": "tsc --noEmit",
		"format": "bunx prettier . --write",
		"lint": "bun x eslint .",
		"lint:fix": "bun x eslint . --fix",
		"prepare": "husky install",
		"deploy": "astro build && bunx wrangler deploy",
		"pre-commit": "bun run tsc && bun run lint && bun run format"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,astro}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.md": [
			"markdownlint-cli2 --fix",
			"prettier --write"
		],
		"*.{json,css}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.4.0",
		"@tailwindcss/vite": "^4.1.8",
		"astro": "5.8.0",
		"clsx": "^2.1.1",
		"lint-staged": "^16.1.0",
		"tailwind-merge": "^3.3.0",
		"tailwindcss": "^4.1.8"
	},
	"devDependencies": {
		"@eslint/js": "^9.28.0",
		"@typescript-eslint/parser": "8.33.0",
		"eslint": "^9.28.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-astro": "^1.3.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-prettier": "^5.4.1",
		"globals": "^16.2.0",
		"husky": "^8.0.3",
		"markdownlint-cli2": "^0.19.0",
		"prettier": "^3.5.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.6.12",
		"sharp": "^0.34.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.33.0",
		"wrangler": "^4.18.0"
	}
}

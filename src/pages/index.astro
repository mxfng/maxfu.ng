---
import HubLayout from "@/layouts/hub-layout.astro";
import JanZoeng from "@/components/jan-zoeng.astro";

const links = [
	{ label: "Drumhaus", href: "https://drumhaus.fung.studio/", external: true },
	{ label: "Writing", href: "/writing", external: false },
	{ label: "Music", href: "/music", external: false },
	{ label: "About", href: "/about", external: false },
];
---

<HubLayout>
	<div class="space-y-12">
		<h1
			class="animate-fade-in-up text-4xl font-medium tracking-tight opacity-0 md:text-5xl"
			style="animation-delay: 0s;"
		>
			Max Fung
		</h1>
		<nav>
			<ul class="space-y-4">
				{
					links.map((link, i) => (
						<li class="animate-fade-in-up opacity-0" style={`animation-delay: ${(i + 1) * 0.05}s;`}>
							<a
								href={link.href}
								target={link.external ? "_blank" : undefined}
								rel={link.external ? "noopener noreferrer" : undefined}
								class="text-muted-foreground hover:text-accent text-lg transition-colors"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
		<div
			class="animate-fade-in-up pt-4 opacity-0"
			style={`animation-delay: ${(links.length + 1) * 0.05}s;`}
		>
			<JanZoeng />
		</div>
	</div>
</HubLayout>

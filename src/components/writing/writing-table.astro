---
import type { CollectionEntry } from "astro:content";

interface Props {
  writings: CollectionEntry<"writing">[];
}

const { writings } = Astro.props;

const sortedWritings = writings?.length
  ? [...writings].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  : [];
---

<div class="w-full overflow-x-auto">
  <table class="w-full border-collapse">
    <thead>
      <tr class="border-border border-b">
        <th
          class="text-muted-foreground py-3 pr-4 text-left text-sm font-medium"
          >Date</th
        >
        <th
          class="text-muted-foreground py-3 pl-4 text-left text-sm font-medium"
          >Title</th
        >
      </tr>
    </thead>
    <tbody>
      {
        sortedWritings.map((writing) => (
          <tr
            class="group border-border h-12 cursor-pointer border-b transition-colors last:border-b-0 md:h-16"
            data-href={`/writing/${writing.slug}`}
            onclick="window.location.href = this.dataset.href"
          >
            <td class="text-muted-foreground py-3 pr-4 text-sm whitespace-nowrap">
              <time datetime={writing.data.date.toISOString()}>
                {writing.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
            </td>
            <td class="py-3 pl-4">
              <span class="group-hover:text-accent transition-colors">
                {writing.data.title}
              </span>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

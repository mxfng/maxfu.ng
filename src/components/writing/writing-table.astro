---
import type { CollectionEntry } from "astro:content";

interface Props {
  writings: CollectionEntry<"writing">[];
}

const { writings } = Astro.props;

const sortedWritings = writings?.length
  ? [...writings].sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  : [];
---

<div class="w-full">
  <div
    class="animate-fade-in-up text-muted-foreground border-border flex border-b py-3 text-sm font-medium opacity-0"
    style="animation-delay: 0.05s;"
  >
    <span class="w-48 shrink-0 pr-4">Date</span>
    <span class="pl-4">Title</span>
  </div>
  {
    sortedWritings.map((writing, i) => (
      <a
        href={`/writing/${writing.slug}`}
        class="animate-fade-in-up border-border group flex h-12 items-center border-b no-underline opacity-0 last:border-b-0 md:h-16"
        style={`animation-delay: ${0.1 + i * 0.05}s;`}
      >
        <time
          datetime={writing.data.date.toISOString()}
          class="text-muted-foreground w-48 shrink-0 pr-4 text-sm whitespace-nowrap"
        >
          {writing.data.date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        <span class="group-hover:text-accent pl-4 transition-colors">
          {writing.data.title}
        </span>
      </a>
    ))
  }
</div>

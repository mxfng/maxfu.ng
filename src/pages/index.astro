---
import HubLayout from "@/layouts/hub-layout.astro";
import HankoSeal from "@/components/hanko-seal.astro";
---

<HubLayout>
	<div class="space-y-12">
		<h1 class="text-4xl font-medium tracking-tight md:text-5xl">Max Fung</h1>
		<nav>
			<ul class="space-y-4">
				<li>
					<a
						href="https://drumhaus.fung.studio/"
						target="_blank"
						rel="noopener noreferrer"
						class="text-muted-foreground hover:text-accent text-lg transition-colors"
					>
						Drumhaus
					</a>
				</li>
				<li>
					<a
						href="/writing"
						class="text-muted-foreground hover:text-accent text-lg transition-colors"
					>
						Writing
					</a>
				</li>
				<li>
					<a
						href="/music"
						class="text-muted-foreground hover:text-accent text-lg transition-colors"
					>
						Music
					</a>
				</li>
				<li>
					<a
						href="/about"
						class="text-muted-foreground hover:text-accent text-lg transition-colors"
					>
						About
					</a>
				</li>
			</ul>
		</nav>
		<div class="pt-4">
			<HankoSeal />
		</div>
	</div>
</HubLayout>

---
import Layout from "@/layouts/layout.astro";
import { Image } from "astro:assets";
import coverLotus from "@/assets/images/cover-lotus.png";
import coverBlueMoon from "@/assets/images/cover-blue-moon.JPG";
import coverFarFromHome from "@/assets/images/cover-far-from-home.png";

const GRID_COLS = 3;

const videos = [
  {
    id: "SO63RmjhmME",
    title: "Barcelona",
    label: "Video",
    year: 2025,
  },
  {
    id: "9CNIUWSzqbc",
    title: "See Through",
    label: "Video",
    year: 2020,
  },
  {
    id: "vXpejWS-UjU",
    title: "Honesty",
    label: "Trailer",
    year: 2020,
  },
  {
    id: "G89Wpx9ex0U",
    title: "Smoke",
    label: "Video",
    year: 2019,
  },
  {
    id: "22mM4PnUYjg",
    title: "Smoke",
    label: "Trailer",
    year: 2019,
  },
  {
    id: "O2LMWKSoY6U",
    title: "Anything",
    label: "Trailer",
    year: 2019,
  },
  {
    id: "6UeD57wDPZc",
    title: "Sweet Dreams",
    label: "Trailer",
    year: 2019,
  },
];

const albums = [
  {
    cover: coverFarFromHome,
    title: "Far From Home",
    year: 2025,
    url: "https://album.link/zphvgmmz7gbqc",
  },
  {
    cover: coverBlueMoon,
    title: "Blue Moon",
    year: 2020,
    url: "https://album.link/br4hxrq46kx07",
  },
  {
    cover: coverLotus,
    title: "Lotus",
    year: 2019,
    url: "https://album.link/xkrc4cgctwccj",
  },
];
---

<Layout title="Music">
  <div class="w-full space-y-16">
    <h1>Music</h1>
    <section>
      <ul class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-6">
        {
          albums.map((album, i) => (
            <li>
              <a
                href={album.url}
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline"
              >
                <Image
                  src={album.cover}
                  alt={`${album.title} album cover`}
                  width={400}
                  loading={i < GRID_COLS ? "eager" : "lazy"}
                  class="aspect-square rounded-lg object-cover transition-opacity hover:opacity-80"
                />
                <p class="mt-3 text-sm font-medium">
                  {album.title}
                  <span class="text-muted-foreground ml-1.5">{album.year}</span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section class="space-y-6">
      <h2>Videos</h2>
      <ul class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-6">
        {
          videos.map((video) => (
            <li>
              <a
                href={`https://www.youtube.com/watch?v=${video.id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="no-underline"
              >
                <img
                  src={`https://img.youtube.com/vi/${video.id}/maxresdefault.jpg`}
                  alt={`${video.title} - ${video.label}`}
                  width={480}
                  height={360}
                  loading="lazy"
                  class="aspect-video rounded-lg object-cover transition-opacity hover:opacity-80"
                />
                <p class="mt-3 text-sm font-medium">
                  {video.title}
                  <span class="text-muted-foreground ml-1.5">
                    {video.label} · {video.year}
                  </span>
                </p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Layout>
